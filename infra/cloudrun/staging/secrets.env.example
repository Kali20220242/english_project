# Cloud SQL and networking
CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project:us-central1:neontalk-staging-sql
VPC_CONNECTOR=projects/your-project/locations/us-central1/connectors/neontalk-staging
VPC_EGRESS=private-ranges-only

# Required Secret Manager keys for data-plane connectivity
API_DATABASE_URL_SECRET=neontalk-staging-api-database-url
API_DIRECT_DATABASE_URL_SECRET=neontalk-staging-api-direct-database-url
WORKER_DATABASE_URL_SECRET=neontalk-staging-worker-database-url
API_REDIS_URL_SECRET=neontalk-staging-api-redis-url
WORKER_REDIS_URL_SECRET=neontalk-staging-worker-redis-url

# Optional secrets (recommended)
API_CSRF_TOKEN_SECRET=neontalk-staging-api-csrf-token
API_FIREBASE_PROJECT_ID_SECRET=neontalk-staging-api-firebase-project-id
API_FIREBASE_CLIENT_EMAIL_SECRET=neontalk-staging-api-firebase-client-email
API_FIREBASE_PRIVATE_KEY_SECRET=neontalk-staging-api-firebase-private-key
API_OPENAI_API_KEY_SECRET=neontalk-staging-api-openai-api-key
WORKER_OPENAI_API_KEY_SECRET=neontalk-staging-worker-openai-api-key
WORKER_ANTHROPIC_API_KEY_SECRET=neontalk-staging-worker-anthropic-api-key
API_ERROR_TRACKING_WEBHOOK_URL_SECRET=neontalk-staging-api-error-tracking-webhook-url
API_ERROR_TRACKING_API_KEY_SECRET=neontalk-staging-api-error-tracking-api-key
WORKER_ERROR_TRACKING_WEBHOOK_URL_SECRET=neontalk-staging-worker-error-tracking-webhook-url
WORKER_ERROR_TRACKING_API_KEY_SECRET=neontalk-staging-worker-error-tracking-api-key
